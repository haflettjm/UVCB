# UVCB Environment Variables
# Copy this to .env and fill in your values

# Discord
UVCB_DISCORD_TOKEN=your-discord-bot-token-here

# VRChat
UVCB_VRCHAT_TOKEN=your-vrchat-token-here

# RTMP Streaming
UVCB_RTMP_STREAM_KEY=your-stream-key-here

# Database (PostgreSQL)
UVCB_DB_PASSWORD=your-db-password-here

# Redis
UVCB_REDIS_PASSWORD=your-redis-password-here

# NATS
UVCB_NATS_TOKEN=your-nats-token-here
